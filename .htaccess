<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Serve actual files from root directly (e.g. robots.txt)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Serve static assets (js/css/images) from public/ folder - internal rewrite, no redirect
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
    RewriteRule ^(.*)$ public/$1 [L,QSA]

    # All other requests to root index.php (Laravel bootstrap)
    RewriteRule ^ index.php [L]
</IfModule>
